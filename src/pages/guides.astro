---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import CtaStrip from '~/components/CtaStrip.astro';

const steps = [
  {
    num: 1,
    title: 'Define Your Why & Budget',
    body: "Before browsing a single listing, get clear on intent and affordability. Owner-occupier and investor decisions look very different — and your budget isn't your loan ceiling.",
    items: [
      'Calculate your TDSR (Total Debt Servicing Ratio) cap of 55%',
      'Apply MSR (Mortgage Servicing Ratio) 30% if buying HDB or EC',
      'Account for BSD, ABSD, legal fees, and renovation buffer (~5–7% on top)',
      'Stress-test your monthly payment against a 4% interest scenario',
    ],
  },
  {
    num: 2,
    title: 'Understand HDB, EC, or Private',
    body: 'Each property class has its own eligibility rules, financing, and resale dynamics. Choosing the wrong category early is one of the costliest mistakes Singaporean buyers make.',
    items: [
      'HDB: BTO vs. resale, MOP, ethnic quotas, income ceilings',
      'Executive Condo: 5-year MOP, 10-year privatisation, hybrid resale rules',
      'Private: freehold vs. 99-year, ABSD considerations for second properties',
      'Decoupling vs. selling — when each makes sense',
    ],
  },
  {
    num: 3,
    title: 'Shortlist by Location & Lifestyle',
    body: 'Don\'t fall for "hot district" lists — those are lagging indicators. Use a personal scoring framework that weighs your real life: commute, schools, family proximity, and future URA master plans.',
    items: [
      'Map your top-3 daily routes against MRT and bus connectivity',
      'Check the URA Master Plan for upcoming amenities and rezoning',
      'Score each shortlist on: lifestyle, growth potential, exit liquidity',
      'Visit the area at three different times (morning, evening, weekend)',
    ],
  },
  {
    num: 4,
    title: 'Evaluate Like an Investor',
    body: 'Even if you\'ll live in the home for 30 years, life happens. Buying with an exit-aware mindset protects your downside and maximises optionality.',
    items: [
      'Compare PSF against 5-year and 10-year district averages',
      "Look at rental yield even if you won't rent — it's a signal of demand",
      'Study unsold inventory and developer pricing power in the area',
      'Identify two clear exit scenarios before signing the OTP',
    ],
  },
  {
    num: 5,
    title: 'Inspect & Compare Showflats',
    body: 'Showflats are theatre. Knowing what to look past — and what to actually scrutinise — separates buyers from spectators.',
    items: [
      'Bring a measuring tape: showflats often display oversized furniture',
      'Ask for the unit mix, sold percentages, and actual floor plan',
      'Check ceiling height, balcony size, and bay window allowances',
      'Compare materials spec across at least three competing launches',
    ],
  },
  {
    num: 6,
    title: 'Secure Financing & OTP',
    body: 'The Option-to-Purchase clock moves fast. Have your financing in place before you commit — not after.',
    items: [
      'Get an In-Principle Approval (IPA) from at least two banks',
      'Compare fixed vs. floating packages over 3-year and 5-year horizons',
      'Understand the OTP timeline: 14-day exercise, 8-week completion',
      "Engage a conveyancing lawyer early — don't wait for OTP signing",
    ],
  },
  {
    num: 7,
    title: 'Handover, Renovation & Beyond',
    body: 'The keys are just the start. The first 90 days set up the next 10 years of ownership cost and enjoyment.',
    items: [
      'Run a thorough defects inspection — document everything in writing',
      'Understand DLP (Defects Liability Period) and how to claim',
      'Plan renovation in phases; avoid over-customising for resale',
      'Set a 3-year and 5-year review point to reassess your hold strategy',
    ],
  },
];

const guidesJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://projecthome.sg/' },
      { '@type': 'ListItem', position: 2, name: 'Buying Guides', item: 'https://projecthome.sg/guides' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to Buy a Home in Singapore: 7-Step Roadmap',
    description: 'A self-help roadmap covering budget, eligibility, location, evaluation, financing, OTP, and handover for Singapore property buyers.',
    image: 'https://projecthome.sg/assets/images/logo.png',
    totalTime: 'P90D',
    estimatedCost: { '@type': 'MonetaryAmount', currency: 'SGD', value: '0' },
    step: steps.map((s) => ({
      '@type': 'HowToStep',
      position: s.num,
      name: s.title,
      text: s.body,
      url: `https://projecthome.sg/guides#step-${s.num}`,
    })),
  },
];
---

<BaseLayout
  title="Singapore Home Buying Guide: 7-Step Roadmap | ProjectHome.sg"
  description="A free 7-step self-help guide to buying property in Singapore — budget & TDSR, HDB vs EC vs private, location framework, financing, OTP, and handover."
  keywords="Singapore home buying guide, how to buy property Singapore, HDB buying guide, EC eligibility, TDSR MSR, Singapore property OTP, first time home buyer Singapore"
  ogType="article"
  active="guides"
  jsonLd={guidesJsonLd}
  whatsappMessage="Hi I need help with a step in the buying guide"
>
  <section class="page-banner">
    <div class="page-banner-inner">
      <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Buying Guides' }]} />
      <span class="eyebrow">Self-Help Buyer Roadmap</span>
      <h1>The 7-Step Singapore Home Buying Guide</h1>
      <p>A structured walkthrough designed to help you make confident decisions at every milestone — whether you're buying your first home or your fourth.</p>
    </div>
  </section>

  <section class="guides">
    <div class="container">
      <div class="steps">
        {steps.map((s) => (
          <article class="step" id={`step-${s.num}`}>
            <div class="step-num">{s.num}</div>
            <div class="step-body">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
              <ul>{s.items.map((item) => <li>{item}</li>)}</ul>
              <a href="/contact" class="step-link">Get personal help with this step <span class="arrow">→</span></a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaStrip
    heading="Stuck on a specific step?"
    body="Real questions deserve real answers. WhatsApp directly and I'll personally help you think it through."
    whatsappMessage="Hi I need help with a step in the buying guide"
  />
</BaseLayout>
