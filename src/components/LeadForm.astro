---
export interface Props {
  variant?: 'enquiry' | 'subscribe';
  heading?: string;
  subheading?: string;
}

const {
  variant = 'enquiry',
  heading = variant === 'subscribe' ? 'Subscribe to updates' : 'Send a quick enquiry',
  subheading = variant === 'subscribe'
    ? "One email per quarter for market reports, plus alerts on launches you'd genuinely want to know about."
    : "Drop your email for updates, or send a short message — I'll personally respond.",
} = Astro.props;
---

<form id="lead-form" class="lead-form" novalidate>
  <h3>{heading}</h3>
  <p class="form-sub">{subheading}</p>
  <div class="form-success" role="status" aria-live="polite"></div>

  {
    variant === 'enquiry' && (
      <div class="field">
        <label for="name">Your Name</label>
        <input type="text" id="name" name="name" placeholder="e.g. Jonathan Tan" />
      </div>
    )
  }

  <div class="field">
    <label for="email">Email Address *</label>
    <input type="email" id="email" name="email" required placeholder="you@example.com" />
  </div>

  {
    variant === 'enquiry' && (
      <>
        <div class="field">
          <label for="phone">Phone (optional)</label>
          <input type="tel" id="phone" name="phone" placeholder="e.g. 9123 4567" />
        </div>
        <div class="field">
          <label for="interest">I'm interested in</label>
          <select id="interest" name="interest">
            <option>Buying my first home</option>
            <option>Upgrading from HDB</option>
            <option>An investment property</option>
            <option>Tracking new launches</option>
            <option>Decoupling advice</option>
            <option>Just exploring for now</option>
          </select>
        </div>
        <div class="field">
          <label for="timeline">Looking to buy</label>
          <select id="timeline" name="timeline">
            <option>Within 3 months</option>
            <option>3 to 6 months</option>
            <option>6 to 12 months</option>
            <option>Over a year out</option>
            <option>No specific timeline</option>
          </select>
        </div>
        <div class="field">
          <label for="message">Message (optional)</label>
          <textarea
            id="message"
            name="message"
            placeholder="Tell me a bit about what you're looking for…"
          />
        </div>
      </>
    )
  }

  {
    variant === 'subscribe' && (
      <div class="field">
        <label for="interest">Most interested in</label>
        <select id="interest" name="interest">
          <option>New launch alerts</option>
          <option>Quarterly market reports</option>
          <option>Buyer guides & how-tos</option>
          <option>District spotlights</option>
          <option>All of the above</option>
        </select>
      </div>
    )
  }

  <label class="checkbox-row">
    <input type="checkbox" name="updates" checked />
    <span
      >Send me occasional new launch alerts and quarterly market reports. No spam, unsubscribe
      anytime.</span
    >
  </label>

  <button type="submit" class="btn btn-primary">
    {variant === 'subscribe' ? 'Subscribe' : 'Submit Enquiry'}
  </button>
</form>
