---
export interface Props {
  heading?: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
  whatsappMessage?: string;
}

const {
  heading = 'Need a quick answer right now?',
  body = "WhatsApp is the fastest way to get a real-person reply on a specific listing, launch, or decision.",
  ctaLabel = 'Chat on WhatsApp',
  whatsappMessage,
  ctaHref = whatsappMessage
    ? `https://wa.me/6582822486?text=${encodeURIComponent(whatsappMessage)}`
    : 'https://wa.me/6582822486',
} = Astro.props;
---

<section class="cta-strip">
  <h2>{heading}</h2>
  <p>{body}</p>
  <a href={ctaHref} target="_blank" rel="noopener" class="btn btn-secondary">{ctaLabel}</a>
</section>
