---
export interface Props {
  href: string;
  title: string;
  excerpt: string;
  category: string;
  categorySlug?: string;
  date: string;
  readingTime?: string;
  coverImage: string;
  coverImageAlt?: string;
}

const {
  href,
  title,
  excerpt,
  category,
  categorySlug = 'all',
  date,
  readingTime = '5 min read',
  coverImage,
  coverImageAlt = title,
} = Astro.props;
---

<article class="post-card" data-category={categorySlug}>
  <a href={href} aria-label={`Read article: ${title}`}>
    <div
      class="post-thumb"
      style={`background-image:url('${coverImage}');`}
      role="img"
      aria-label={coverImageAlt}
    >
      <span class="tag">{category}</span>
    </div>
  </a>
  <div class="post-body">
    <div class="post-meta">{date} · {readingTime}</div>
    <h3><a href={href} style="color:inherit">{title}</a></h3>
    <p>{excerpt}</p>
    <a href={href} class="read-more">Read article <span class="arrow">→</span></a>
  </div>
</article>
