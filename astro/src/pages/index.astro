---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'RealEstateAgent',
      '@id': 'https://projecthome.sg/#organization',
      name: 'ProjectHome.sg',
      alternateName: 'Singapore Property Guide — ProjectHome.sg',
      url: 'https://projecthome.sg/',
      logo: 'https://projecthome.sg/assets/images/logo.png',
      image: 'https://projecthome.sg/assets/images/logo.png',
      description: 'Independent Singapore property advisory co-founded by ProjectHome.sg and Renee Lim, District Directors at Huttons Asia.',
      telephone: '+65 8282 2486',
      areaServed: { '@type': 'Country', name: 'Singapore' },
      address: { '@type': 'PostalAddress', addressCountry: 'SG', addressLocality: 'Singapore' },
      contactPoint: [
        { '@type': 'ContactPoint', name: 'Jason Sim', telephone: '+65 8282 2486', contactType: 'customer service', areaServed: 'SG', availableLanguage: ['English'] },
        { '@type': 'ContactPoint', name: 'Renee Lim', telephone: '+65 8827 5656', contactType: 'customer service', areaServed: 'SG', availableLanguage: ['English'] },
      ],
      founder: [
        { '@type': 'Person', '@id': 'https://projecthome.sg/jason-sim#person', name: 'Jason Sim', jobTitle: 'District Director', worksFor: { '@type': 'Organization', name: 'Huttons Asia Pte Ltd', identifier: 'L3008899K' }, identifier: 'R052528Z', telephone: '+65 8282 2486' },
        { '@type': 'Person', '@id': 'https://projecthome.sg/renee-lim#person', name: 'Renee Lim', jobTitle: 'District Director', worksFor: { '@type': 'Organization', name: 'Huttons Asia Pte Ltd', identifier: 'L3008899K' }, identifier: 'R047234H', telephone: '+65 8827 5656' },
      ],
      employee: [
        { '@id': 'https://projecthome.sg/jason-sim#person' },
        { '@id': 'https://projecthome.sg/renee-lim#person' },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://projecthome.sg/#website',
      url: 'https://projecthome.sg/',
      name: 'ProjectHome.sg',
      publisher: { '@id': 'https://projecthome.sg/#organization' },
      inLanguage: 'en-SG',
    },
    {
      '@type': 'WebPage',
      '@id': 'https://projecthome.sg/#webpage',
      url: 'https://projecthome.sg/',
      name: 'Singapore Property Guide | ProjectHome.sg',
      isPartOf: { '@id': 'https://projecthome.sg/#website' },
      about: { '@id': 'https://projecthome.sg/#organization' },
      inLanguage: 'en-SG',
    },
  ],
};
---

<BaseLayout
  title="Singapore Property Guide | ProjectHome.sg"
  description="Independent Singapore property advisory by ProjectHome.sg — co-founded by District Directors at Huttons Asia. Step-by-step home buying guides, new launch reviews, and quarterly market reports for HDB, EC, and private property buyers."
  keywords="Singapore property, home buying guide Singapore, new launch Singapore, HDB resale, EC, private property, ProjectHome.sg, Singapore real estate"
  canonical="https://projecthome.sg/"
  ogDescription="Independent Singapore property advisory by ProjectHome.sg — co-founded by District Directors at Huttons Asia. Step-by-step home buying guides, new launch reviews, and quarterly market reports."
  twitterDescription="Independent Singapore property advisory. Step-by-step home buying guides and market reports."
  schema={schema}
>

  <link slot="head-extra" rel="preconnect" href="https://images.unsplash.com" />
  <link slot="head-extra" rel="preload" as="image" href="/assets/images/hero-couple-planning.png" fetchpriority="high" />

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-copy">
        <span class="hero-ornament" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 3l9 9"/><path d="M5 10v10h14V10"/></svg>
        </span>
        <span class="eyebrow">Singapore Property · Self-Guided Advisory</span>
        <h1>Find Your <em>Ideal Home</em><br />Without the Guesswork</h1>
        <p class="lead">ProjectHome.sg gives you the playbook used by experienced buyers — step-by-step guides, market data, and curated new launch updates so you can move with clarity and confidence.</p>
        <div class="hero-actions">
          <a href="/7-steps-buyer-framework" class="btn btn-primary">Start the Buyer Roadmap <span class="arrow">→</span></a>
          <a href="/blog" class="btn btn-outline" style="color:#f7f1e8; border-color:#d19557;">Latest Market Reports</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><div class="num" data-counter="7">0</div><div class="label">Guided Steps</div></div>
          <div class="stat"><div class="num" data-counter="100" data-suffix="+">0</div><div class="label">New Launches Tracked</div></div>
          <div class="stat"><div class="num" data-counter="24" data-suffix="h">0</div><div class="label">Reply Promise</div></div>
        </div>
      </div>
      <figure class="hero-media">
        <img src="/assets/images/hero-couple-planning.png" alt="A Singapore couple reviewing property options together over coffee — the kind of considered decision ProjectHome.sg is built to support." width="1200" height="960" fetchpriority="high" decoding="async" />
        <span class="hero-badge" aria-hidden="true"><span class="dot"></span>Real buyers, real decisions</span>
      </figure>
    </div>
  </section>

  <section class="trust-strip" aria-label="What we cover">
    <div class="container">
      <div class="trust-inner">
        <div class="trust-label">Coverage across</div>
        <div class="trust-pills">
          <span class="trust-pill"><span class="dot"></span>HDB BTO &amp; Resale</span>
          <span class="trust-pill"><span class="dot"></span>Executive Condos</span>
          <span class="trust-pill"><span class="dot"></span>Private Property</span>
          <span class="trust-pill"><span class="dot"></span>New Launches</span>
          <span class="trust-pill"><span class="dot"></span>All 28 Districts</span>
        </div>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">What You Get</span>
        <h2>Everything you need to buy with confidence</h2>
        <p>A few pointers here to help you go from "just looking" to keys in hand — built for Singapore's HDB, EC, and private property landscape.</p>
      </div>
      <div class="feature-grid">
        <article class="feature-card"><div class="feature-icon" aria-hidden="true">🧭</div><h3>Step-by-Step Roadmap</h3><p>From budgeting and TDSR to OTP, walk through every milestone with checklists you can actually use.</p></article>
        <article class="feature-card"><div class="feature-icon" aria-hidden="true">📊</div><h3>Market Reports</h3><p>Quarterly performance data, district trends, and rental yields — distilled so you can spot the right window to enter.</p></article>
        <article class="feature-card"><div class="feature-icon" aria-hidden="true">🏗️</div><h3>New Launch Coverage</h3><p>Honest takes on every major launch — pricing, layouts, and the long-term outlook beyond the marketing spin.</p></article>
        <article class="feature-card"><div class="feature-icon" aria-hidden="true">💬</div><h3>Direct Founder Access</h3><p>Stuck on a specific decision? WhatsApp us directly for fast, private answers to your real questions.</p></article>
        <article class="feature-card"><div class="feature-icon" aria-hidden="true">🔍</div><h3>NAVIS PrimeKey Analysis</h3><p>No fluff, no pressure. The information you'd want a friend in the industry to share with you.</p></article>
        <article class="feature-card"><div class="feature-icon" aria-hidden="true">📩</div><h3>Curated Updates</h3><p>Subscribe to receive launch alerts and market notes — no spam, only what genuinely moves your decision.</p></article>
      </div>
    </div>
  </section>

  <section class="guides">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">The Buyer Roadmap</span>
        <h2>A clear path from "thinking about it" to handover</h2>
        <p>The home-buying journey, broken into seven structured stages. Start at step one or jump to the milestone you're stuck on.</p>
      </div>
      <div class="steps">
        <article class="step"><div class="step-num">1</div><div class="step-body"><h3>Define Your Why &amp; Budget</h3><p>Clarify whether this is a home for living, an investment, or both — then nail down your real affordability using TDSR and MSR.</p><a href="/7-steps-buyer-framework#step-1" class="step-link">Open this step <span class="arrow">→</span></a></div></article>
        <article class="step"><div class="step-num">2</div><div class="step-body"><h3>Understand HDB, EC, or Private</h3><p>Eligibility rules, resale levy, MOP, and the tradeoffs between each property class — explained without the jargon.</p><a href="/7-steps-buyer-framework#step-2" class="step-link">Open this step <span class="arrow">→</span></a></div></article>
        <article class="step"><div class="step-num">3</div><div class="step-body"><h3>Shortlist by Location &amp; Lifestyle</h3><p>Use a structured framework to weigh schools, transport, future URA plans, and your daily routine — not just price.</p><a href="/7-steps-buyer-framework#step-3" class="step-link">Open this step <span class="arrow">→</span></a></div></article>
        <article class="step"><div class="step-num">4</div><div class="step-body"><h3>Evaluate Like an Investor</h3><p>Even owner-occupiers should think about exit. Learn the metrics that matter: PSF trends, rental yield, and 10-year outlook.</p><a href="/7-steps-buyer-framework#step-4" class="step-link">Open this step <span class="arrow">→</span></a></div></article>
      </div>
      <p style="text-align:center; margin-top:40px;"><a href="/7-steps-buyer-framework" class="btn btn-secondary">See All 7 Steps</a></p>
    </div>
  </section>

  <section class="blog-section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">From the Journal</span>
        <h2>Latest Insights &amp; Market Notes</h2>
        <p>New launch reviews, quarterly market reports, and timely commentary on what's shaping Singapore's property scene.</p>
      </div>
      <div class="blog-grid">
        <article class="post-card" data-category="report">
          <a href="/blog/hdb-resale-q1-2026-first-price-dip"><div class="post-thumb" style="background-image:url('/assets/images/hdb-bukit-merah-cbd-skyline.jpg');" role="img" aria-label="Bukit Merah / Telok Blangah HDB blocks with Singapore CBD skyline behind"><span class="tag">Market Report</span></div></a>
          <div class="post-body">
            <div class="post-meta">May 2026 · 7 min read</div>
            <h3><a href="/blog/hdb-resale-q1-2026-first-price-dip" style="color:inherit">HDB Resale Prices Just Fell for the First Time Since 2019. Here's What It Actually Means.</a></h3>
            <p>The Q1 2026 HDB resale price index dipped 0.1% — the first quarterly decline in seven years. The headline hides a more interesting story for buyers, sellers, and upgraders.</p>
            <a href="/blog/hdb-resale-q1-2026-first-price-dip" class="read-more">Read article <span class="arrow">→</span></a>
          </div>
        </article>
        <article class="post-card" data-category="report">
          <a href="/blog/ec-rule-changes-2026"><div class="post-thumb" style="background-image:url('/assets/images/mostafa_meraji-buildings-4917447.jpg');" role="img" aria-label="Modern Singapore high-rise residential development"><span class="tag">Market Report</span></div></a>
          <div class="post-body">
            <div class="post-meta">May 2026 · 6 min read</div>
            <h3><a href="/blog/ec-rule-changes-2026" style="color:inherit">The EC Rule Shake-Up: What Singapore's New Executive Condo Rules Mean for You</a></h3>
            <p>Singapore overhauled the EC framework on 8 May 2026 — 10-year MOP, 15-year privatisation, 90% first-timer quota, end of DPS. Here's what changed and where the opportunities are.</p>
            <a href="/blog/ec-rule-changes-2026" class="read-more">Read article <span class="arrow">→</span></a>
          </div>
        </article>
        <article class="post-card" data-category="guide">
          <a href="/blog/first-time-homebuyer-singapore-2026"><div class="post-thumb" style="background-image:url('/assets/images/chena-couple-955926_1920.jpg');" role="img" aria-label="Young Asian couple planning their first home purchase in Singapore"><span class="tag">Buyer Guide</span></div></a>
          <div class="post-body">
            <div class="post-meta">May 2026 · 9 min read</div>
            <h3><a href="/blog/first-time-homebuyer-singapore-2026" style="color:inherit">HDB or Condo for Your First Home? An Honest 2026 Decision Guide</a></h3>
            <p>The four questions that decide HDB vs Condo, with honest income brackets, downpayment math, and the three real choices most Singapore first-timers face.</p>
            <a href="/blog/first-time-homebuyer-singapore-2026" class="read-more">Read article <span class="arrow">→</span></a>
          </div>
        </article>
      </div>
      <p style="text-align:center; margin-top:40px;"><a href="/blog" class="btn btn-outline">Browse All Articles</a></p>
    </div>
  </section>

  <section class="testimonials">
    <div class="container">
      <div class="section-head">
        <div class="divider-ornament" aria-hidden="true"><span class="line"></span><span class="glyph"></span><span class="line"></span></div>
        <span class="eyebrow">From Buyers Like You</span>
        <h2>Clarity, in their words</h2>
        <p>What readers and clients say after working through the roadmap or chatting on WhatsApp.</p>
      </div>
      <div class="testimonial-grid">
        <article class="testimonial-card"><div class="stars" aria-label="5 out of 5 stars">★★★★★</div><p class="testimonial-quote">"the ProjectHome.sg roadmap saved us from rushing into the wrong launch. We finally felt like we were buying with a strategy, not a sales pitch."</p><div class="testimonial-attribution"><div class="testimonial-avatar" aria-hidden="true">JL</div><div class="testimonial-meta"><div class="name">Jonathan &amp; Li-Anne</div><div class="role">First-time buyers · Tampines</div></div></div></article>
        <article class="testimonial-card"><div class="stars" aria-label="5 out of 5 stars">★★★★★</div><p class="testimonial-quote">"Honest take on the launch I was eyeing. WhatsApp reply within an hour, no pressure to engage anything else. Refreshing."</p><div class="testimonial-attribution"><div class="testimonial-avatar" aria-hidden="true">PR</div><div class="testimonial-meta"><div class="name">Priya R.</div><div class="role">HDB upgrader · Bishan</div></div></div></article>
        <article class="testimonial-card"><div class="stars" aria-label="5 out of 5 stars">★★★★★</div><p class="testimonial-quote">"The market reports are the only ones I actually read end-to-end. Data-led, no fluff, and the Q1 call on RCR was spot on."</p><div class="testimonial-attribution"><div class="testimonial-avatar" aria-hidden="true">DK</div><div class="testimonial-meta"><div class="name">Daniel K.</div><div class="role">Investor · CCR portfolio</div></div></div></article>
        <article class="testimonial-card"><div class="stars" aria-label="5 out of 5 stars">★★★★★</div><p class="testimonial-quote">"The NAVIS PrimeKey Analysis Zoom Consultation was the turning point. In one hour we mapped out our upgrade timeline, the right districts to shortlist, and the financing structure — clearer than three months of solo research."</p><div class="testimonial-attribution"><div class="testimonial-avatar" aria-hidden="true">MT</div><div class="testimonial-meta"><div class="name">Marcus &amp; Tricia</div><div class="role">HDB upgraders · Sengkang to OCR condo</div></div></div></article>
        <article class="testimonial-card"><div class="stars" aria-label="5 out of 5 stars">★★★★★</div><p class="testimonial-quote">"I shortlisted three projects and asked for the NAVIS PrimeKey Analysis Report on each. The side-by-side on PSF history, unit-mix, and rental comps made my decision obvious. Genuinely useful for anyone purchasing seriously."</p><div class="testimonial-attribution"><div class="testimonial-avatar" aria-hidden="true">SC</div><div class="testimonial-meta"><div class="name">Shannon C.</div><div class="role">Investor · D15 freehold purchase</div></div></div></article>
        <article class="testimonial-card"><div class="stars" aria-label="5 out of 5 stars">★★★★★</div><p class="testimonial-quote">"We came in thinking we wanted a new launch and walked away with a resale unit that fit us much better. The team asked the right questions and never once pushed a specific listing."</p><div class="testimonial-attribution"><div class="testimonial-avatar" aria-hidden="true">AW</div><div class="testimonial-meta"><div class="name">Adrian W.</div><div class="role">Second-time buyer · East Coast</div></div></div></article>
      </div>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Frequently Asked</span>
        <h2>The questions buyers ask first</h2>
        <p>Quick answers to the things people enquire about most. Need more depth? <a href="/contact">Drop a message</a>.</p>
      </div>
      <div class="faq-list">
        <details class="faq-item"><summary class="faq-summary">Is ProjectHome.sg free to use?<span class="icon" aria-hidden="true">+</span></summary><div class="faq-body">Yes. The full 7-step buying guide, all blog posts, and market reports are free to read. WhatsApp enquiries are also free — no obligation to engage us as your agent, including PrimeKey Analysis Zoom Consultation and Report generation are complimentary.</div></details>
        <details class="faq-item"><summary class="faq-summary">Do you cover HDB and ECs, or only private property?<span class="icon" aria-hidden="true">+</span></summary><div class="faq-body">All three. The roadmap is property-class agnostic — and we publish dedicated guides on BTO vs. resale, EC eligibility, decoupling for couples, and CCR/RCR/OCR private launches.</div></details>
        <details class="faq-item"><summary class="faq-summary">How quickly do you respond on WhatsApp?<span class="icon" aria-hidden="true">+</span></summary><div class="faq-body">Within one business day for sure — usually within a few hours during Singapore working hours. Late nights and weekends, you'll get a reply the next morning.</div></details>
        <details class="faq-item"><summary class="faq-summary">Is ProjectHome.sg an independent advisor?<span class="icon" aria-hidden="true">+</span></summary><div class="faq-body">ProjectHome.sg is co-founded by two District Directors at Huttons Asia, one of Singapore's largest private real estate agencies. The content here is independent of any specific developer's marketing — opinions on launches, districts, and pricing are their own.</div></details>
        <details class="faq-item"><summary class="faq-summary">I'm not buying for another year. Is it too early to reach out?<span class="icon" aria-hidden="true">+</span></summary><div class="faq-body">Not at all — early is better. The buyers who get the best outcomes typically start 12–18 months before purchase, so they can watch the market, refine their criteria, and act when the right opportunity appears.</div></details>
      </div>
    </div>
  </section>

  <section class="contact" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <span class="eyebrow" style="color:#d19557; letter-spacing:0.22em; text-transform:uppercase; font-size:0.8rem; font-weight:600;">Get In Touch</span>
          <h2 style="margin-top:14px;">Have a question? Two ways to reach us.</h2>
          <p>Whether you're months away from buying or just sense-checking an article you read, we'd love to hear from you. No pressure, no auto-responder.</p>
          <div class="contact-channels">
            <a href="https://wa.me/6582822486?text=Hi%2C%20I%27m%20enquiring%20via%20ProjectHome.sg%2C%20regarding%20" target="_blank" rel="noopener" class="channel">
              <div class="channel-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4l-2.4-1.1c-.3-.1-.7-.1-.9.2l-1.1 1.4c-1.7-.8-3.1-2.2-3.9-3.9l1.4-1.1c.3-.2.4-.6.2-.9L9.6 6.5c-.2-.4-.6-.6-1-.5l-2 .5c-.4.1-.7.5-.7.9 0 4.7 3.8 8.5 8.5 8.5.4 0 .8-.3.9-.7l.5-2c.1-.4-.1-.8-.3-.8z"/></svg></div>
              <div class="channel-text"><span class="label">Quick Chat</span><span class="value">WhatsApp +65 8282 2486</span></div>
            </a>
            <div class="channel">
              <div class="channel-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
              <div class="channel-text"><span class="label">Email Updates</span><span class="value">Use the form to subscribe →</span></div>
            </div>
            <div class="channel">
              <div class="channel-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
              <div class="channel-text"><span class="label">Reply Time</span><span class="value">Within one business day</span></div>
            </div>
          </div>
        </div>

        <form id="lead-form" class="lead-form" novalidate>
          <h3>Send a quick enquiry</h3>
          <p class="form-sub">Drop your email for updates, or send a short message — we will personally respond.</p>
          <div class="form-success" role="status" aria-live="polite"></div>
          <div class="hp-field" aria-hidden="true"><label for="website">Don't fill this out if you're human</label><input type="text" id="website" name="website" tabindex="-1" autocomplete="off" /></div>
          <div class="field"><label for="name">Your Name</label><input type="text" id="name" name="name" placeholder="e.g. Jonathan Tan" /></div>
          <div class="field"><label for="email">Email Address *</label><input type="email" id="email" name="email" required placeholder="you@example.com" /></div>
          <div class="field"><label for="interest">I'm interested in</label><select id="interest" name="interest"><option>Buying my first home</option><option>Upgrading from HDB</option><option>An investment property</option><option>Tracking new launches</option><option>NAVIS PrimeKey Analysis Report</option><option>NAVIS PrimeKey Analysis Zoom Consultation</option><option>Just exploring for now</option></select></div>
          <div class="field"><label for="message">Message (optional)</label><textarea id="message" name="message" placeholder="Tell us a bit about what you're looking for…"></textarea></div>
          <label class="checkbox-row"><input type="checkbox" name="updates" checked /><span>Send me occasional new launch alerts and quarterly market reports. No spam, unsubscribe anytime.</span></label>
          <button type="submit" class="btn btn-primary">Submit Enquiry</button>
        </form>
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <h2>Need a quick answer right now?</h2>
    <p>WhatsApp us directly for a real-person reply on a specific listing, launch, or decision.</p>
    <a href="https://wa.me/6582822486?text=Hi%2C%20I%27m%20enquiring%20via%20ProjectHome.sg%2C%20regarding%20" target="_blank" rel="noopener" class="btn btn-secondary">Chat on WhatsApp</a>
  </section>

</BaseLayout>
