---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://projecthome.sg/' },
        { '@type': 'ListItem', position: 2, name: 'About', item: 'https://projecthome.sg/about' },
        { '@type': 'ListItem', position: 3, name: 'Jason Sim', item: 'https://projecthome.sg/jason-sim' },
      ],
    },
    {
      '@type': 'ProfilePage',
      '@id': 'https://projecthome.sg/jason-sim#profilepage',
      url: 'https://projecthome.sg/jason-sim',
      name: 'Jason Sim — Co-Founder, ProjectHome.sg',
      inLanguage: 'en-SG',
      mainEntity: { '@id': 'https://projecthome.sg/jason-sim#person' },
    },
    {
      '@type': 'Person',
      '@id': 'https://projecthome.sg/jason-sim#person',
      name: 'Jason Sim',
      jobTitle: 'District Director',
      image: 'https://projecthome.sg/assets/images/jason-sim.jpg',
      url: 'https://projecthome.sg/jason-sim',
      telephone: '+65 8282 2486',
      description: 'Co-founder of ProjectHome.sg. District Director at Huttons Asia. Independent Singapore property advisor helping families, upgraders, and investors navigate HDB, EC, and private property decisions through structured frameworks and market insights.',
      worksFor: { '@type': 'Organization', name: 'Huttons Asia Pte Ltd', identifier: 'L3008899K' },
      identifier: 'R052528Z',
      knowsAbout: ['Singapore real estate', 'HDB resale', 'Executive Condominium', 'Private property', 'New launch advisory', 'Property investment'],
    },
  ],
};
---

<BaseLayout
  title="Jason Sim | Co-Founder & District Director, Huttons Asia — ProjectHome.sg"
  description="Meet Jason Sim, co-founder of ProjectHome.sg and District Director at Huttons Asia. Independent Singapore property advisory built on clarity, strategy, and trust."
  keywords="Jason Sim Huttons, District Director Huttons Asia, Singapore property advisor, R052528Z, ProjectHome.sg founder"
  canonical="https://projecthome.sg/jason-sim"
  ogTitle="Jason Sim | Co-Founder, ProjectHome.sg"
  ogDescription="District Director at Huttons Asia. Co-founder of ProjectHome.sg."
  ogImage="https://projecthome.sg/assets/images/jason-sim.jpg"
  ogType="article"
  twitterTitle="Jason Sim | Co-Founder, ProjectHome.sg"
  twitterDescription="District Director at Huttons Asia. Independent Singapore property advisor."
  author="Jason Sim · ProjectHome.sg"
  whatsappContext="Jason Sim's profile"
  schema={schema}
>

  <section class="about-hero">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep" aria-hidden="true">›</span>
        <a href="/about">About</a>
        <span class="sep" aria-hidden="true">›</span>
        <span class="current" aria-current="page">Jason Sim</span>
      </nav>
    </div>
    <div class="about-grid">
      <div class="about-photo-frame">
        <img src="/assets/images/jason-sim.jpg?v=142" alt="Jason Sim, Co-Founder of ProjectHome.sg and District Director at Huttons Asia" loading="eager" decoding="async" />
      </div>
      <div class="about-text">
        <span class="eyebrow">Co-Founder · ProjectHome.sg</span>
        <h1>Jason Sim</h1>
        <div class="about-title">District Director · Huttons Asia</div>
        <p>ProjectHome.sg is the independent property advisory platform, co-founded and built by Jason Sim to help buyers navigate Singapore's real estate market with greater clarity, structure, and confidence.</p>
        <p>In a market filled with fast-moving trends, aggressive marketing, and overwhelming information, Jason believes property decisions should be guided by strategy — not pressure or emotion.</p>
        <div class="about-creds">
          <div class="about-cred-item"><strong>Mobile · WhatsApp</strong><a href="https://wa.me/6582822486?text=Hi%20Jason%2C%20I%27d%20like%20to%20enquire%20about%20property%20in%20Singapore" target="_blank" rel="noopener" style="color:inherit;">+65 8282 2486</a></div>
          <div class="about-cred-item"><strong>RES Reg No</strong>R052528Z</div>
          <div class="about-cred-item"><strong>Agency Licence No</strong>L3008899K</div>
          <img src="/assets/images/huttons-logo.png" alt="Huttons Asia — Singapore's Largest Private Real Estate Agency" class="about-huttons-logo" loading="eager" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <section class="about-body">
    <div class="about-body-inner">
      <h2>A strategic approach to Singapore property</h2>
      <p>Through ProjectHome.sg's proven frameworks, analytical methods, and market insights, clients are empowered to make sound and informed property decisions aligned with their long-term goals.</p>
      <p>Whether you are planning for your first home, considering an upgrade from your HDB, exploring investment opportunities, or evaluating a new launch, Jason provides practical guidance grounded in real market experience and strategic planning.</p>

      <h2>The focus: right home, right asset, right future</h2>
      <p>More than just buying a property, the focus is on helping clients secure <strong>the right home, the right asset, and the right future</strong>.</p>
      <p>Connect with Jason Sim to explore a clearer and more strategic approach towards your next property decision.</p>

      <h2>Areas of focus</h2>
      <ul>
        <li>First-time HDB and EC buyers planning their long-term path</li>
        <li>HDB upgraders moving into private property</li>
        <li>Decoupling and second-property strategy for married couples</li>
        <li>New launch evaluation and unit selection</li>
        <li>Investment-grade district and project analysis</li>
      </ul>

      <h2>Get in touch with Jason</h2>
      <p>The best way to reach Jason is WhatsApp at <a href="https://wa.me/6582822486?text=Hi%2C%20I%27m%20enquiring%20via%20ProjectHome.sg%2C%20regarding%20" target="_blank" rel="noopener">+65 8282 2486</a> — every message is read personally, with replies typically within a few hours during Singapore working hours and at most one business day. You can also <a href="/contact">drop a message</a> through the contact form.</p>

      <div class="about-disclosure">
        <strong>Professional Disclosure</strong>
        Jason Sim is a registered Real Estate Salesperson with the Council for Estate Agencies (CEA), Singapore. RES Registration Number: R052528Z. He is licensed to practise estate agency work under Huttons Asia Pte Ltd, Estate Agent Licence Number: L3008899K. Content on ProjectHome.sg is provided for educational and informational purposes and does not constitute personalised financial, legal, or investment advice. Property decisions should be made in consultation with qualified professionals based on your individual circumstances.
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <h2>Ready to start a conversation with Jason?</h2>
    <p>WhatsApp is the fastest way to reach Jason for a real-person reply on a specific listing, launch, or decision.</p>
    <a href="https://wa.me/6582822486?text=Hi%20Jason%2C%20I%27d%20like%20to%20talk%20through%20my%20Singapore%20property%20plans" target="_blank" rel="noopener" class="btn btn-secondary">Chat with Jason on WhatsApp</a>
  </section>

</BaseLayout>
