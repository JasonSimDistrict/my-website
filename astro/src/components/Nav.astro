---
// Site header + nav. Active-state highlighting is computed from Astro.url.pathname
// at render time, so the same component handles every page automatically.
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (path: string) => pathname === path;
const activeClass = (path: string) => (isActive(path) ? 'active' : '');
---

<header class="site-header">
  <nav class="nav" aria-label="Main">
    <a href="/" class="brand">
      <img src="/assets/images/logo.png" alt="ProjectHome.sg logo" />
      <span class="brand-text">
        <span class="name">ProjectHome.sg</span>
        <span class="tag">Clarity, Direction, Your New Home</span>
      </span>
    </a>
    <button class="nav-toggle" aria-expanded="false" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li><a href="/" class={activeClass('/')}>Home</a></li>

      <li class="nav-has-submenu">
        <span class="nav-parent" tabindex="0" role="button" aria-haspopup="true">Buying Guides</span>
        <ul class="nav-submenu">
          <li><a href="/7-steps-buyer-framework" class={activeClass('/7-steps-buyer-framework')}>7 Steps Buyer Framework</a></li>
          <li><a href="/navis-primekey-analysis" class={activeClass('/navis-primekey-analysis')}>NAVIS PrimeKey Analysis</a></li>
        </ul>
      </li>

      <li class="nav-has-submenu">
        <span class="nav-parent" tabindex="0" role="button" aria-haspopup="true">Insights & News</span>
        <ul class="nav-submenu">
          <li><a href="/blog" class={activeClass('/blog')}>Insights & News</a></li>
          <li><a href="/blog/new-launches" class={activeClass('/blog/new-launches')}>New Launch</a></li>
        </ul>
      </li>

      <li class="nav-has-submenu">
        <span class="nav-parent" tabindex="0" role="button" aria-haspopup="true">About</span>
        <ul class="nav-submenu">
          <li><a href="/about" class={activeClass('/about')}>ProjectHome.sg</a></li>
          <li><a href="/our-services" class={activeClass('/our-services')}>Our Services</a></li>
          <li><a href="/jason-sim" class={activeClass('/jason-sim')}>Jason Sim</a></li>
          <li><a href="/renee-lim" class={activeClass('/renee-lim')}>Renee Lim</a></li>
        </ul>
      </li>

      <li><a href="/contact" class={activeClass('/contact')}>Contact</a></li>
      <li><a href="/contact" class="nav-cta">Get In Touch</a></li>
    </ul>
  </nav>
</header>
